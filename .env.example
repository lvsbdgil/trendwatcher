# LLM — OpenAI (основная модель). Без ключа пайплайн работает в rule-based режиме.
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# LLM — Gemini (верификатор сигналов). Опционально: добавляет Gemini-проверку топ-сигналов.
# Ключ: console.cloud.google.com → APIs → Generative Language API
GEMINI_API_KEY=your_gemini_key_here

FIRECRAWL_API_KEY=your_firecrawl_key_here

# --- Auth / Admin ---
# SESSION_SECRET (он же JWT_SECRET) генерируется автоматически на сервере при
# первом старте и сохраняется на диск рядом с SQLite
# (data/.session_secret или /app/var/.session_secret в Docker).
# Задавать вручную не нужно. Можно зафиксировать своим значением:
# SESSION_SECRET=change_me_long_random_secret
# JWT_SECRET=change_me_long_random_secret

# Только HTTPS — выставить true в проде, на локали оставить пустым.
SESSION_COOKIE_SECURE=

# ADMIN_LOGIN и ADMIN_PASSWORD задаются на сервере или через GitHub Secrets.
# Создают/обновляют админа автоматически при старте backend.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me
# Альтернатива: готовый bcrypt-хеш вместо plaintext.
# ADMIN_PASSWORD_HASH=

# CORS — список разрешённых origin'ов фронтенда, через запятую.
# В dev обычно не нужно (vite proxy + same-origin). Для prod-доменов:
# FRONTEND_URL=https://trendwatcher.example.com

# Путь до SQLite (по умолчанию data/app.db, в docker — /app/var/app.db).
# APP_DB_PATH=
